{
  "manifest_version": 3,
  "name": "HearAdjust",
  "version": "0.1.0",
  "description": "Real-time audio frequency adjustment based on your hearing profile.",
  "permissions": [
    "activeTab",
    "tabCapture",
    "offscreen",
    "storage"
  ],
  "background": {
    "service_worker": "src/js/background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}